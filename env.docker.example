# Copy to `.env` in the repo root and adjust, then: docker compose --env-file .env up --build
# Mongo: point at your existing container (published on host) or host.docker.internal.

# true = all logged-in users see the same stats/history (global Mongo tail). false = per-GitHub-user only.
SHARED_ANALYTICS=true

MONGO_URI=mongodb://host.docker.internal:27017/fraud-detection
ML_SERVICE_URL=http://ml-service:8000/predict

JWT_SECRET=replace-with-long-random-secret

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must match the callback URL configured in your GitHub OAuth app (use UI port 8080 when using compose frontend).
GITHUB_CALLBACK_URL=http://localhost:8080/auth/github/callback
# Where users land after login (nginx serves the SPA here in Docker).
FRONTEND_URL=http://localhost:8080
